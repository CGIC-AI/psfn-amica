NEXT_PUBLIC_DEVELOPMENT_BASE_URL=http://localhost:3000

# PSFN-backed chat
NEXT_PUBLIC_CHATBOT_BACKEND=psfn
NEXT_PUBLIC_OPENAI_URL=http://127.0.0.1:3100
NEXT_PUBLIC_OPENAI_MODEL=psfn
NEXT_PUBLIC_OPENAI_APIKEY=
NEXT_PUBLIC_PSFN_CHANNEL_TYPE=psfn-amica
NEXT_PUBLIC_PSFN_CHANNEL_ID=psfn-amica:<site>:<device>
NEXT_PUBLIC_PSFN_SATELLITE_BRIDGE_ENABLED=true

# Deployment-owned identity. Resolve placeholders from PSFN-managed settings.
NEXT_PUBLIC_NAME={{char}}
NEXT_PUBLIC_SYSTEM_PROMPT=
NEXT_PUBLIC_VRM_URL=/vrm/<your-model>.vrm
NEXT_PUBLIC_ELEVENLABS_VOICEID={{elevenlabs_voice_id}}

# Voice / UI options
NEXT_PUBLIC_TTS_BACKEND=piper
NEXT_PUBLIC_STT_BACKEND=whisper_browser
NEXT_PUBLIC_AMICA_LIFE_ENABLED=true
NEXT_PUBLIC_AMICA_LIFE_MODE=animation_only
NEXT_PUBLIC_HTTP_REFERER=

# Optional local bridge
AMICA_BRIDGE_TOKEN=
